<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OpenClaw.SetupEngine.UI.SetupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="QVerisBot Setup">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar drag region with icon + text -->
        <Grid x:Name="TitleBarDrag" Grid.Row="0" Padding="12,0,0,0">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Image Source="ms-appx:///Assets/Setup/Lobster.png" Width="20" Height="20" />
                <TextBlock Text="QVerisBot Setup" FontSize="13" Opacity="0.85"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Content -->
        <Frame x:Name="RootFrame" Grid.Row="1" />
    </Grid>

</Window>
